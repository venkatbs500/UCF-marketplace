# Knight Market — environment variables (copy to `.env.local`)

# Supabase project URL (Dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon / publishable key only — never use service_role in the frontend
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Auth: supabase (real magic link) or local (E2E/CI mock auth)
NEXT_PUBLIC_AUTH_MODE=supabase

# Product: real (no fake catalog) or demo (mock data for previews/E2E)
NEXT_PUBLIC_PRODUCT_MODE=real

NEXT_PUBLIC_APP_URL=https://ucf-marketplace.vercel.app

# UI-only admin email allowlist (comma-separated).
# This is public env and only gates admin UI visibility.
NEXT_PUBLIC_ADMIN_EMAILS=your-email@ucf.edu

# Notes:
# - Local dev: NEXT_PUBLIC_APP_URL=http://127.0.0.1:3000
# - Vercel production: NEXT_PUBLIC_APP_URL=https://ucf-marketplace.vercel.app (no trailing slash)
# - Supabase Auth Site URL: https://ucf-marketplace.vercel.app
# - Supabase Redirect URLs must include:
#     https://ucf-marketplace.vercel.app/auth/callback
#     http://127.0.0.1:3000/auth/callback
#     http://localhost:3000/auth/callback
# - Magic links must land on /auth/callback (not the site root).
# - For reliable email delivery, configure custom SMTP in Supabase (see docs/supabase-auth-setup.md).
# - Use the anon/publishable key only. Never commit service_role keys.
# - E2E (`npm run e2e`) overrides AUTH_MODE=local and PRODUCT_MODE=demo internally.
# - Real Supabase admin authorization requires adding your auth user to public.admin_users.
# - Do not commit `.env.local`.
